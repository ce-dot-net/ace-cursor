# Source files
src/**
*.ts
!*.d.ts
tsconfig.json

# Development files
.vscode/**
.gitignore
.eslintrc.json
*.md
!README.md
!CHANGELOG.md

# Test files
test/**
*.test.ts
*.test.js

# Build artifacts (keep dist/)
*.map

# Dependencies — esbuild bundles everything from src/ into dist/extension.js.
# node_modules is NOT needed at runtime (the bundle inlines @ace-sdk/core etc).
# @ace-sdk/mcp is loaded via npx at activation, also not from node_modules here.
# Excluding cuts VSIX from ~25 MB / 9785 files to ~500 KB / ~150 files —
# stays well under Open VSX upload limits.
node_modules/**

# Dev / local-tooling artifacts that should NOT ship with the extension
.cursor/**
.serena/**
.ace-cache/**

# Coverage + build maps + test outputs
*.map
coverage/**
test-extension.vsix
test-v*.vsix
cursor-ace-extension-*.vsix

# IDE files
.idea/**
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Cache and data files
.ace-cache/**
.claude/**
*.db
