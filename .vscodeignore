# Source files
src/**
*.ts
!*.d.ts
tsconfig.json

# Development files
.vscode/**
.gitignore
.eslintrc.json
*.md
!README.md
!CHANGELOG.md

# Test files
test/**
*.test.ts
*.test.js

# Build artifacts (keep dist/)
*.map

# Dependencies — esbuild bundles almost everything from src/ into
# dist/extension.js (including @ace-sdk/core, linguist-js, skott — see
# esbuild.js external list). Only better-sqlite3 cannot be bundled
# because it ships a native .node binary.
#
# vsce walks the prod-deps tree by default and adds back the runtime
# prod deps (better-sqlite3 + bindings). Dev deps + the bundled deps
# stay excluded by this rule.
node_modules/**

# Dev / local-tooling artifacts that should NOT ship with the extension
.cursor/**
.serena/**
.ace-cache/**

# Coverage + build maps + test outputs
*.map
coverage/**
test-extension.vsix
test-v*.vsix
cursor-ace-extension-*.vsix

# IDE files
.idea/**
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Cache and data files
.ace-cache/**
.claude/**
*.db
