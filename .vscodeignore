# Source files
src/**
*.ts
!*.d.ts
tsconfig.json

# Development files
.vscode/**
.gitignore
.eslintrc.json
*.md
!README.md
!CHANGELOG.md

# Test files
test/**
*.test.ts
*.test.js

# Build artifacts (keep dist/)
*.map

# Dependencies — esbuild bundles almost everything from src/ into
# dist/extension.js (including @ace-sdk/core, linguist-js, skott — see
# esbuild.js external list). Only better-sqlite3 cannot be bundled
# because it ships a native .node binary.
#
# Blanket-exclude node_modules then re-include exactly the runtime
# prod deps. The vsce dep walker does NOT override .vscodeignore
# exclusions for the deps tree, so this whitelist is required.
node_modules/**
!node_modules/better-sqlite3/**
!node_modules/bindings/**
!node_modules/linguist-js/**
!node_modules/skott/**

# Re-include transitive deps that linguist-js + skott require at runtime.
# Listed individually instead of `!node_modules/**` because we DO want
# blanket dev-deps exclude.
!node_modules/binary-extensions/**
!node_modules/common-path-prefix/**
!node_modules/cross-fetch/**
!node_modules/ignore/**
!node_modules/isbinaryfile/**
!node_modules/js-yaml/**
!node_modules/node-cache/**
!node_modules/@parcel/**
!node_modules/@typescript-eslint/**
!node_modules/commander/**
!node_modules/compression/**
!node_modules/depcheck/**
!node_modules/digraph-js/**
!node_modules/effect/**
!node_modules/estree-walker/**
!node_modules/fp-ts/**
!node_modules/ignore-walk/**
!node_modules/io-ts/**
!node_modules/is-wsl/**
!node_modules/json5/**
!node_modules/kleur/**
!node_modules/lodash-es/**
!node_modules/meriyah/**
!node_modules/minimatch/**
!node_modules/nanospinner/**
!node_modules/parse-gitignore/**
!node_modules/polka/**
!node_modules/sirv/**
!node_modules/typescript/**
!node_modules/fs-tree-structure/**
!node_modules/skott-webapp/**

# Inside better-sqlite3, exclude install-time / source / docs to shave
# ~9 MB of unnecessary C source. The .node binary stays.
node_modules/better-sqlite3/deps/**
node_modules/better-sqlite3/src/**
node_modules/better-sqlite3/docs/**
node_modules/better-sqlite3/test/**
node_modules/better-sqlite3/benchmark/**
node_modules/better-sqlite3/binding.gyp
node_modules/better-sqlite3/CHANGELOG.md
node_modules/better-sqlite3/HACKING.md

# Dev / local-tooling artifacts that should NOT ship with the extension
.cursor/**
.serena/**
.ace-cache/**

# Coverage + build maps + test outputs
*.map
coverage/**
test-extension.vsix
test-v*.vsix
cursor-ace-extension-*.vsix

# IDE files
.idea/**
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Cache and data files
.ace-cache/**
.claude/**
*.db
